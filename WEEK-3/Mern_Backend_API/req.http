Cookie: token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6Im1hbnVAbWFpbC5jb20iLCJpYXQiOjE3NzI4Nzg0ODgsImV4cCI6MTc3Mjg3ODQ5OH0.p0L09CEOhvmKZJRzRPD9kroLnbS_25SXmfN_UbXaBEA; Path=/; HttpOnly; SameSite=Lax

{
    "username":"moulya",
    "password":"moulya",
    "email":"moulya@mail.com",
    "age": 19
}

